@model BookAndOrder.ViewModels.AccountViewModels.ProfileViewModel

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0 rounded-4 p-4">
                <h2 class="fw-bold text-navy mb-4 border-bottom pb-2">My profile</h2>

                <form asp-action="UpdateProfile" method="post">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold small">Email</label>
                            <input asp-for="Email" class="form-control bg-light" readonly />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="FirstName" class="form-label fw-bold small"></label>
                            <input asp-for="FirstName" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="LastName" class="form-label fw-bold small"></label>
                            <input asp-for="LastName" class="form-control" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Address" class="form-label fw-bold small"></label>
                        <input asp-for="Address" class="form-control" placeholder="Streetname..." />
                    </div>

                    <div class="row">
                        <div class="col-md-8 mb-3">
                            <label asp-for="City" class="form-label fw-bold small"></label>
                            <input asp-for="City" class="form-control" />
                        </div>
                        <div class="col-md-4 mb-4">
                            <label asp-for="Postcode" class="form-label fw-bold small"></label>
                            <input asp-for="Postcode" class="form-control" />
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary px-5 shadow-sm">Save changes</button>
                </form>
            </div>
        </div>
    </div>
</div>