@model BookAndOrder.ViewModels.Home.HomeViewModel
@{
    ViewData["Title"] = "Welcome";
    var products = Model.FeaturedProducts.ToList();
}

@* HERO *@
<section id="heroCarousel" class="carousel slide shadow-lg rounded-4 overflow-hidden mb-5" data-bs-ride="carousel">
    <div class="carousel-indicators" style="z-index: 15;">
        @for (int i = 0; i < products.Count; i++)
        {
            <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="@i" class="@(i == 0 ? "active" : "")"></button>
        }
    </div>

    <div class="carousel-inner">
        @for (int i = 0; i < products.Count; i++)
        {
            var prod = products[i];
            <div class="carousel-item @(i == 0 ? "active" : "")" data-bs-interval="5000">
                <div class="hero-slide d-flex align-items-center bg-navy text-white">
                    <div class="container">
                        <div class="row align-items-center">
                            <div class="col-md-6 px-4">
                                <span class="badge bg-orange mb-2">NEW ARRIVAL</span>
                                <h1 class="display-4 fw-bold">@prod.Name</h1>
                                <p class="lead opacity-75 text-truncate-2">@prod.Description</p>
                                <div class="mt-4 d-flex align-items-center">
                                    <a asp-controller="Products" asp-action="Details" asp-route-id="@prod.ProductId"
                                       class="btn btn-info btn-lg text-white shadow-sm me-3 view-product">View Product</a>
                                    <span class="ms-3 fs-3 fw-bold text-white">@prod.Price kr</span>
                                </div>
                            </div>
                            <div class="col-md-6 text-center d-none d-md-block">
                                <img src="@prod.ImageUrl" class="img-fluid rounded-3 shadow hero-img">
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @* CONTROLS *@
    <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
    </button>
</section>

@* LORE *@
<section>
    <div class="row py-5 border-top border-bottom my-5 g-4 text-center">
        <div class="col-6 col-md-3">
            <i class="bi bi-truck text-orange fs-2"></i>
            <div class="fw-bold mt-2">Fast Delivery</div>
        </div>
        <div class="col-6 col-md-3">
            <i class="bi bi-shield-check text-orange fs-2"></i>
            <div class="fw-bold mt-2">Secure Shop</div>
        </div>
        <div class="col-6 col-md-3">
            <i class="bi bi-arrow-repeat text-orange fs-2"></i>
            <div class="fw-bold mt-2">Free Returns</div>
        </div>
        <div class="col-6 col-md-3">
            <i class="bi bi-chat-dots text-orange fs-2"></i>
            <div class="fw-bold mt-2">24/7 Support</div>
        </div>
    </div>
</section>

@* CATEGORIES *@
<section class="container my-5 pt-4 text-center">
    <h6 class="text-uppercase text-muted small fw-bold mb-5">Explore our products</h6>
    <div class="d-flex flex-wrap justify-content-center gap-4 gap-md-5">
        @foreach (var cat in Model.RandomCategories)
        {
            <a asp-controller="Products" asp-action="Index" asp-route-categoryId="@cat.CategoryId"
               class="category-link text-decoration-none">
                <span class="display-6 fw-light text-navy text-uppercase hover-underline">@cat.Name</span>
            </a>
        }
    </div>
</section>

