@{
    ViewData["Title"] = "Thanks you!";
}

<div class="container py-5 text-center">
    <div class="card shadow border-0 rounded-4 p-5">
        <div class="mb-4">
            <i class="bi bi-check-circle-fill text-success" style="font-size: 5rem;"></i>
        </div>
        <h1 class="display-5 fw-bold text-navy">Thank you for your order!</h1>
        <p class="lead text-muted mb-4">Your order number is: <span class="text-orange fw-bold">#@ViewBag.OrderId</span></p>

        <div class="bg-light p-4 rounded-3 mb-4 mx-auto" style="max-width: 500px;">
            <p class="mb-0">A confirmation email has been sent. We'll start packing your order right away!</p>
        </div>

        <div>
            <a asp-controller="Products" asp-action="Index" class="btn btn-primary btn-lg px-5">
                Continue Shopping
            </a>
        </div>
    </div>
</div>