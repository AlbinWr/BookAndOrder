@model IEnumerable<BookAndOrder.Models.Order>

<div class="container py-5">
    <h2 class="fw-bold text-navy mb-4">Your orders!</h2>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            No orders placed yet! <a asp-controller="Products" asp-action="Index">Start shopping here!</a>
        </div>
    }
    else
    {
        @foreach (var order in Model)
        {
            @* Order Information *@
            <div class="card shadow-sm border-0 mb-4 rounded-4">
                <div class="card-header bg-navy text-white d-flex justify-content-between align-items-center p-3">
                    <span>Order #@order.OrderId</span>
                    <span>@order.OrderDate.ToString("yyyy-MM-dd HH:mm")</span>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-8">
                            <h6 class="fw-bold text-navy mb-3">Products:</h6>
                            <ul class="list-unstyled">
                                @foreach (var item in order.OrderItems)
                                {
                                    <li class="mb-2 d-flex justify-content-between border-bottom pb-1">
                                        <span>@item.Quantity x @item.Product.Name</span>
                                        <span class="text-muted">@item.Price kr</span>
                                    </li>
                                }
                            </ul>
                        </div>

                        @* Payment section *@
                        <div class="col-md-4 text-end d-flex flex-column justify-content-center border-start">
                            <p class="text-muted mb-1">Total amount:</p>
                            <h4 class="fw-bold text-orange">@order.TotalAmount kr</h4>

                            @if (order.IsPaid)
                            {
                                <span class="badge bg-success align-self-end mt-2">Paid</span>
                            }
                            else
                            {
                                <span class="badge bg-warning align-self-end mt-2">Pending</span>

                                <form asp-controller="Order" asp-action="MarkAsPaid" method="post" class="align-self-end w-100 mt-2">
                                    <input type="hidden" name="orderId" value="@order.OrderId" />
                                    <button type="submit" class="btn btn-primary btn-sm w-100 rounded-pill shadow-sm">
                                        Pay Now
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>