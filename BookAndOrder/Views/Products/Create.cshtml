@model BookAndOrder.Models.Product

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow border-0 rounded-3">
                @* Header *@
                <div class="card-header bg-navy text-white py-3">
                    <h3 class="mb-0 text-white">Create New Product</h3>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Create" enctype="multipart/form-data" method="post">

                        @* Product Name *@
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-bold">Product Name</label>
                            <input asp-for="Name" class="form-control" placeholder="Enter product name" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="row">
                            @* Price *@
                            <div class="col-md-6 mb-3">
                                <label asp-for="Price" class="form-label fw-bold">Price</label>
                                <div class="input-group">
                                    <input asp-for="Price" class="form-control" type="number" step="0.01" />
                                    <span class="input-group-text bg-light text-navy fw-bold">kr</span>
                                </div>
                                <span asp-validation-for="Price" class="text-danger"></span>
                            </div>

                            @* Stock *@
                            <div class="col-md-6 mb-3">
                                <label asp-for="Stock" class="form-label fw-bold">Stock Quantity</label>
                                <input asp-for="Stock" class="form-control" type="number" />
                                <span asp-validation-for="Stock" class="text-danger"></span>
                            </div>
                        </div>

                        @* Description *@
                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-bold">Description</label>
                            <textarea asp-for="Description" class="form-control" rows="3" placeholder="Write a short summary..."></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        @* Category Select *@
                        <div class="mb-3">
                            <label asp-for="CategoryId" class="form-label fw-bold">Category</label>
                            <select asp-for="CategoryId" class="form-select"
                                    asp-items="@(new SelectList(ViewBag.CategoryList, "CategoryId", "Name"))">
                                <option value="">-- Select a category --</option>
                            </select>
                            <span asp-validation-for="CategoryId" class="text-danger"></span>
                        </div>

                        @* Image Upload *@
                        <div class="mb-4">
                            <label asp-for="Image" class="form-label fw-bold">Product Image</label>
                            <input asp-for="Image" type="file" class="form-control" accept="image/*" />
                            <span asp-validation-for="Image" class="text-danger"></span>
                        </div>

                        @* Buttons *@
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg">Save Product</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}