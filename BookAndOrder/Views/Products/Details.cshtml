@model BookAndOrder.ViewModels.ProductViewModels.ProductDetailsViewModel

@{
    ViewData["Title"] = Model.Name;
}

<div class="container my-5">
    <div class="row g-4">

        @* Left side: Product Image *@
        <div class="col-md-5">
            <div class="card border-0 shadow-sm overflow-hidden rounded-4">
                <img src="@Model.ImageUrl" alt="@Model.Name" class="img-fluid" style="width: 100%; object-fit: contain; padding: 20px;" />

                @if (Model.Stock <= 0)
                {
                    <div class="bg-danger text-white text-center py-2 fw-bold">
                        OUT OF STOCK
                    </div>
                }
            </div>
        </div>

        @* Right side: Information and Purchase *@
        <div class="col-md-7">
            <nav class="mb-2">
                <a asp-action="Index" class="text-navy text-decoration-none small fw-bold">Products</a>
                <span class="text-muted small"> / @Model.CategoryName</span>
            </nav>

            <h1 class="display-5 fw-bold text-navy mb-2">@Model.Name</h1>
            <p class="h2 text-orange fw-bold mb-4">@Model.Price kr</p>

            <div class="mb-4">
                <h5 class="fw-bold text-navy">Description</h5>
                <p class="text-muted" style="line-height: 1.6;">
                    @Model.Description
                </p>
            </div>

            <div class="row mb-4 bg-light p-3 rounded-3 mx-0">
                <div class="col-6 border-end">
                    <small class="text-muted d-block">Category</small>
                    <span class="fw-bold text-navy">@Model.CategoryName</span>
                </div>
                <div class="col-6">
                    <small class="text-muted d-block">Stock Status</small>
                    <span class="fw-bold @(Model.Stock > 0 ? "text-success" : "text-danger")">
                        <i class="bi @(Model.Stock > 0 ? "bi-check-circle" : "bi-x-circle")"></i>
                        @(Model.Stock > 0 ? $"{Model.Stock} in stock" : "Out of Stock")
                    </span>
                </div>
            </div>

            @* Buttons *@
            <div class="mt-4 pt-3 border-top">
                @if (Model.Stock > 0)
                {
                    <form asp-controller="Cart" asp-action="AddToCart" method="post" class="mb-3">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <input type="hidden" name="productName" value="@Model.Name" />
                        <button type="submit" class="btn btn-primary btn-lg w-100 py-3 shadow-sm">
                            <i class="bi bi-cart-plus me-2"></i> Add to cart
                        </button>
                    </form>
                }

                <a asp-action="Index" class="btn btn-outline-secondary w-100 py-2">
                    Back to products
                </a>
            </div>

            @* Admin (Edit/Delete) *@
            @if (User.IsInRole("Admin"))
            {
                <div class="mt-5 p-3 border rounded bg-white shadow-sm" style="border-style: dashed !important;">
                    <p class="text-muted small mb-2 fw-bold">ADMIN CONTROLS</p>
                    <div class="d-flex gap-2">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-navy">
                            <i class="bi bi-pencil"></i> Edit
                        </a>

                        <form asp-action="Delete" asp-route-id="@Model.Id" method="post"
                              onsubmit="return confirm('Delete this product?');">
                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash"></i> Delete
                            </button>
                        </form>
                    </div>
                </div>
            }
        </div>
    </div>
</div>