@model BookAndOrder.ViewModels.ProductViewModels.ProductEditViewModel

@{
    ViewData["Title"] = "Edit Product";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card shadow border-0 rounded-3">
                @* Header *@
                <div class="card-header bg-navy text-white py-3">
                    <h3 class="mb-0 text-white"> Edit: @Model.Name</h3>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Edit" enctype="multipart/form-data" method="post">
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="ImageUrl" />

                        <div class="row">
                            @* Left side: Form fields *@
                            <div class="col-md-7">
                                <div class="mb-3">
                                    <label asp-for="Name" class="form-label fw-bold">Product Name</label>
                                    <input asp-for="Name" class="form-control" />
                                    <span asp-validation-for="Name" class="text-danger"></span>
                                </div>

                                @* Price and Stock *@
                                <div class="row">
                                    <div class="col-6 mb-3">
                                        <label asp-for="Price" class="form-label fw-bold">Price (kr)</label>
                                        <input asp-for="Price" class="form-control" type="number" step="0.01" />
                                        <span asp-validation-for="Price" class="text-danger"></span>
                                    </div>
                                    <div class="col-6 mb-3">
                                        <label asp-for="Stock" class="form-label fw-bold">Stock</label>
                                        <input asp-for="Stock" class="form-control" type="number" />
                                        <span asp-validation-for="Stock" class="text-danger"></span>
                                    </div>
                                </div>

                                @* Category Select *@
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Category</label>
                                    <select asp-for="CategoryId" class="form-select"
                                            asp-items="@(new SelectList(ViewBag.CategoryList, "CategoryId", "Name"))">
                                    </select>
                                </div>

                                @* Description *@
                                <div class="mb-3">
                                    <label asp-for="Description" class="form-label fw-bold">Description</label>
                                    <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                                </div>
                            </div>

                            @* Right side : Image *@
                            <div class="col-md-5 border-start">
                                <div class="ps-md-4">
                                    <label class="form-label fw-bold">Current Image</label>
                                    <div class="mb-3">
                                        <img src="@Model.ImageUrl" alt="Current image" class="img-thumbnail d-block mx-auto" style="max-height: 200px;">
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label fw-bold">Change Image</label>
                                        <input asp-for="NewImage" type="file" class="form-control" accept="image/*" />
                                        <small class="text-muted">Keep empty if you don't want to change image.</small>
                                    </div>
                                </div>
                            </div>
                        </div>

                        @* Buttons *@
                        <div class="mt-4 pt-3 border-top">
                            <button type="submit" class="btn btn-primary px-5">Save Changes</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}