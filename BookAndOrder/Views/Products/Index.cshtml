@using BookAndOrder.ViewModels.ProductViewModels
@model IEnumerable<ProductViewModel>

@{
    ViewData["Title"] = "Our Products";
}

<div class="container my-5">
    @* Title and Create *@
    <div class="row mb-4 align-items-center">
        <div class="col-md-4">
            <h1 class="fw-bold">Our Products</h1>
        </div>

        <div class="col-md-4">
            @* Category Dropdown *@
            <form asp-action="Index" method="get" class="d-flex gap-2">
                <input type="hidden" name="searchString" value="@ViewData["CurrentFilter"]" />

                <select name="categoryId" class="form-select border-0 shadow-sm" onchange="this.form.submit()">
                    <option value="">All Categories</option>
                    @foreach (var cat in ViewBag.Categories)
                    {
                        @if (ViewBag.SelectedCategory == cat.CategoryId)
                        {
                            <option value="@cat.CategoryId" selected>@cat.Name</option>
                        }
                        else
                        {
                            <option value="@cat.CategoryId">@cat.Name</option>
                        }
                    }
                </select>
            </form>
        </div>
        @* Add New Products *@
        <div class="col-md-4 text-end">
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="Create" class="btn btn-success rounded-pill px-4 shadow-sm">
                    <i class="bi bi-plus-circle"></i> Add New Product
                </a>
            }
        </div>
    </div>

    @* Product Grid *@
    <div class="row">
        @if (Model != null && Model.Any())
        {
            @foreach (var product in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100 border-0 shadow-sm">
                        @* Product Image *@
                        <img src="@product.ImageUrl" class="card-img-top" style="height: 200px; object-fit: contain; padding: 10px;">

                        <div class="card-body">
                            <small class="text-muted">@product.CategoryName</small>
                            <h5 class="card-title fw-bold">@product.Name</h5>

                            <div class="d-flex justify-content-between align-items-center">
                                <span class="fw-bold text-orange">@product.Price kr</span>

                                @* Stock *@
                                @if (product.Stock <= 5 && product.Stock > 0)
                                {
                                    <span class="text-danger small fw-bold">Only @product.Stock left!</span>
                                }
                                @if (product.Stock > 50)
                                {
                                    <span class="badge bg-success border border-success">Plenty</span>
                                }
                            </div>

                            @* Buttons *@
                            <div class="mt-3">
                                @if (product.Stock > 0)
                                {
                                    <form asp-controller="Cart" asp-action="AddToCart" method="post">
                                        <input type="hidden" name="id" value="@product.Id" />
                                        <input type="hidden" name="productName" value="@product.Name" />
                                        <button type="submit" class="btn btn-primary w-100">
                                            <i class="bi bi-cart-plus"></i> Buy
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <button class="btn btn-secondary w-100" disabled>Out of Stock</button>
                                }
                                <a asp-action="Details" asp-route-id="@product.Id" class="btn btn-light border w-100 mt-2">
                                    Details
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
        <div class="col-12 text-center py-5">
            <h3 class="mt-3 text-secondary">No products found</h3>
            <p class="text-muted">Try adjusting your filters or search for something else.</p>
                <a asp-action="Index" class="btn btn-primary mt-2">Show all products</a>
        </div>
        }
    </div>
</div>