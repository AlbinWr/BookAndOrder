@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@using BookAndOrder.Interfaces
@inject ICartService CartService

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BookAndOrder</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BookAndOrder.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
</head>
<body>
    <header>
        @* Navbar *@
        <nav class="navbar navbar-expand-lg navbar-dark navbar-custom shadow-sm mb-4">
            <div class="container d-flex align-items-center justify-content-between position-relative">

                @* Logo *@
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                    <span>Book<span class="text-info">And</span>Order</span>
                </a>

                @* Cart and User Dropdown *@
                <div class="d-flex align-items-center ms-auto order-lg-last">

                    @* Cart *@
                    <a class="nav-link text-light position-relative px-2 me-2" asp-controller="Cart" asp-action="Index">
                        <i class="bi bi-cart2 fs-4 nav-link-simple"></i>
                        @if (CartService.GetCartCount() > 0)
                        {
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-orange">
                                @CartService.GetCartCount()
                            </span>
                        }
                    </a>

                    @* User dropdown *@
                    @if (SignInManager.IsSignedIn(User))
                    {
                        <div class="dropdown">
                            <a class="nav-link dropdown-toggle text-white px-2" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-person-circle fs-4 nav-link-simple"></i>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0" aria-labelledby="userDropdown">
                                @if (User.IsInRole("Admin"))
                                {
                                    <li class="px-3 py-1"><span class="badge bg-danger w-100">Admin Mode</span></li>
                                    <li><a class="dropdown-item fw-bold" asp-controller="Category" asp-action="Index">Manage Categories</a></li>
                                    <li><a class="dropdown-item fw-bold" asp-controller="Products" asp-action="Create">Add New Product</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                }
                                <li><a class="dropdown-item" asp-controller="Account" asp-action="Profile">Profile</a></li>
                                <li><a class="dropdown-item" asp-controller="Order" asp-action="ShowUserOrders">Orders</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post">
                                        <button type="submit" class="dropdown-item text-danger">Logout</button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a class="nav-link text-light px-2" asp-controller="Account" asp-action="Login">
                            <i class="bi bi-box-arrow-in-right fs-4"></i>
                        </a>
                    }

                    @* Hamburger *@
                    <button class="navbar-toggler border-0 ms-2" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                </div>

                @* Search and Products link *@
                <div class="collapse navbar-collapse" id="navbarMain">
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link-simple text-light text-decoration-none" asp-controller="Products" asp-action="Index">Products</a>
                        </li>
                    </ul>

                    <form class="d-flex justify-content-center col-lg-6 mx-auto mt-2 mt-lg-0" asp-controller="Products" asp-action="Index" method="get">
                        <div class="input-group">
                            <input class="form-control" type="search" name="searchString" placeholder="Search..." value="@ViewData["CurrentFilter"]">
                            <button class="btn btn-primary" type="submit"><i class="bi bi-search"></i></button>
                        </div>
                    </form>
                </div>
            </div>
        </nav>

    </header>
    <div class="container">
        <div class="message-container">
            @* Success Message *@
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show shadow-sm custom-alert" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @* Error Message *@
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show shadow-sm custom-alert" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
        </div>

        <main role="main" class="min-height: 100vh pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - BookAndOrder - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <script>
        @* Show and hide success alert after 2.5 seconds *@
        document.addEventListener("DOMContentLoaded", function () {
            const alertBoxes = document.querySelectorAll('.alert');
            if(alertBox) {
                setTimeout(function () {
                    alertBox.classList.remove('show');
                    setTimeout(function() {
                        alertBox.remove();
                    }, 500);
                }, 2500);
            }
        });
    </script>
</body>
</html>

